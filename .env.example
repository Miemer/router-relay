# ── Inbound auth: tokens opencode/clients must send as `Authorization: Bearer <token>` ──
# Comma-separated list. Empty = OPEN relay (dev only — never use empty in production).
RELAY_API_KEYS=

# ── Upstream OpenAI-compatible provider (where the relay forwards to) ──
# OpenAI example:
UPSTREAM_BASE_URL=https://maas.marketingforce.com/v1
UPSTREAM_API_KEY=
# OpenRouter example (uncomment to use):
# UPSTREAM_BASE_URL=https://openrouter.ai/api/v1
# UPSTREAM_API_KEY=sk-or-...
# Optional OpenAI-Organization header (leave blank otherwise):
UPSTREAM_ORGANIZATION=

# ── Model fallback: used only if a request body has no `model` field ──
# (opencode normally sends the model id, so this is just a safety net)
DEFAULT_MODEL=

# ── Server ──
LISTEN_HOST=127.0.0.1
LISTEN_PORT=8787
UPSTREAM_TIMEOUT=600
LOG_LEVEL=info

# ── P1 Router ──
# Master switch. false = pure passthrough (P0). true = classify each turn and
# route to a tier model (overrides the model opencode sent).
ROUTER_ENABLED=true
# Run + record decisions but do NOT override the client model. Safe rollout to
# validate the rule scorer before trusting it.
ROUTER_OBSERVE_ONLY=true
# Hard budget for scoring (seconds). Timeout → passthrough.
ROUTER_TIMEOUT_SECONDS=2.0
# Sticky window (recent turns kept per session for anti-flapping).
ROUTER_STICKY_TURNS=3
# Margin below this → confidence_gate upgrades one tier.
ROUTER_CONFIDENCE_THRESHOLD=0.55
# Context length (chars, ≈4×tokens) above which large_context_floor → c2.
ROUTER_LARGE_CONTEXT_CHARS=64000
# Optional SQLite path for decision records. Empty = in-memory ring only.
ROUTER_DECISION_DB=

ROUTER_CAPTURE_DIR=./logs
ROUTER_ML_MODEL_PATH=./models/p3_lightgbm.txt
# When true, also write the last user message text to router-raw-*.jsonl for
# LLM-as-judge offline labeling. Default false = no prompt text stored.
CAPTURE_RAW_CONTENT=true
# Log routing decisions at INFO.
ROUTER_LOG_DECISIONS=true
# Tier → model mapping as JSON. Empty = built-in preset for marketingforce
# (c0=qwen3-max, c1=deepseek-r1, c2=gpt-5.4, c3=claude-opus-4-8).
# Example override (single tier):
# ROUTER_TIERS={"c3":{"model":"claude-opus-4-8"}}
ROUTER_TIERS={"c3":{"model":"gpt-5.5"}}

# ── P2 Ensemble (B5 fusion: N proposers → 1 aggregator) ──
# Requires ROUTER_ENABLED=true. Only fires for routed tiers >= ENSEMBLE_MIN_TIER
# so easy turns stay single-model. Proposers run in parallel (non-stream); the
# aggregator fuses their drafts via a <CANDIDATE> prompt.
ENSEMBLE_ENABLED=false
# Comma-separated proposer model ids. The routed anchor model is auto-prepended.
ENSEMBLE_PROPOSERS=
# Aggregator model id; empty = use the routed anchor as aggregator.
ENSEMBLE_AGGREGATOR=
# Only fuse when routed tier rank >= this (c0<c1<c2<c3).
ENSEMBLE_MIN_TIER=c2
# Quorum: minimum successful proposers before aggregation.
ENSEMBLE_MIN_SUCCESSFUL=2
ENSEMBLE_PROPOSER_TIMEOUT=60
ENSEMBLE_AGGREGATOR_TIMEOUT=120
# Truncate each candidate draft to this many chars in the aggregator prompt.
ENSEMBLE_CANDIDATE_MAX_CHARS=24000
